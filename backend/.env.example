# Server
PORT=4000

# Supabase Postgres connection string
# Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URI (port 6543) for serverless-friendly
# pooling, or the direct connection (port 5432) — either works here.
# Replace [YOUR-PASSWORD] with your actual database password.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres

# Google Gemini API key — used for both embeddings and RAG answers
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Firebase Auth verification
# Set to false while developing if you haven't set up a service account
# yet. MUST be true (or removed) before your final demo/submission.
REQUIRE_AUTH=false

# Path to your Firebase service account JSON (only needed if REQUIRE_AUTH=true)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json